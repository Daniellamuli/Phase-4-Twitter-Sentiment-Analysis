    "def evaluate_model(name, model, X_test, y_test, average='weighted'):\n",
    "    y_pred = model.predict(X_test)\n",
    "    return {\n",
    "        'name':      name,\n",
    "        'model':     model,\n",
    "        'accuracy':  accuracy_score(y_test, y_pred),\n",
    "        'precision': precision_score(y_test, y_pred, average=average, zero_division=0),\n",
    "        'recall':    recall_score(y_test, y_pred,    average=average, zero_division=0),\n",
    "        'f1':        f1_score(y_test, y_pred,        average=average, zero_division=0),\n",
    "        'y_pred':    y_pred,\n",
    "    }\n",
    "\n",
    "results = [\n",
    "    evaluate_model('Logistic Regression (Binary)',  lr_model,  X_test_b, y_test_b),\n",
    "    evaluate_model('Naive Bayes (Binary)',           nb_model,  X_test_b, y_test_b),\n",
    "    evaluate_model('Random Forest (Multiclass)',     rf_model,  X_test_m, y_test_m),\n",
    "    evaluate_model('SVM (Multiclass)',               svm_model, X_test_m, y_test_m),\n",
    "]\n",
